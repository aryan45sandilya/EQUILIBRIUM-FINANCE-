// Prisma Schema for Equilibrium Finance
// Full-stack expense splitter with debt simplification

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  clerkId      String?  @unique
  email        String   @unique
  name         String
  passwordHash String   @default("")
  avatar       String?
  currency     String   @default("INR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  groupMemberships  GroupMember[]
  paidExpenses      Expense[]         @relation("PaidBy")
  expenseSplits     ExpenseSplit[]
  sentSettlements   Settlement[]      @relation("SettlementFrom")
  receivedSettlements Settlement[]    @relation("SettlementTo")
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  receipts          Receipt[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Groups ───────────────────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  currency    String   @default("INR")
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]

  @@map("groups")
}

model GroupMember {
  id       String          @id @default(cuid())
  groupId  String
  userId   String
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

enum GroupMemberRole {
  ADMIN
  MEMBER
}

// ─── Expenses ─────────────────────────────────────────────────────────────────

model Expense {
  id          String      @id @default(cuid())
  groupId     String
  title       String
  amount      Float
  currency    String      @default("INR")
  category    String      @default("Other")
  splitType   SplitType   @default(EQUAL)
  paidById    String
  date        DateTime    @default(now())
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  group       Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy      User           @relation("PaidBy", fields: [paidById], references: [id])
  splits      ExpenseSplit[]
  receipt     Receipt?

  @@map("expenses")
}

model ExpenseSplit {
  id        String @id @default(cuid())
  expenseId String
  userId    String
  amount    Float  // Exact share amount for this user
  percent   Float? // Used when splitType = PERCENTAGE
  shares    Int?   // Used when splitType = SHARES

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

enum SplitType {
  EQUAL
  PERCENTAGE
  EXACT
  SHARES
}

// ─── Settlements ──────────────────────────────────────────────────────────────

model Settlement {
  id        String           @id @default(cuid())
  groupId   String
  fromId    String
  toId      String
  amount    Float
  currency  String           @default("INR")
  status    SettlementStatus @default(PENDING)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  from  User  @relation("SettlementFrom", fields: [fromId], references: [id])
  to    User  @relation("SettlementTo", fields: [toId], references: [id])

  @@map("settlements")
}

enum SettlementStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ─── Receipts ─────────────────────────────────────────────────────────────────

model Receipt {
  id        String   @id @default(cuid())
  expenseId String   @unique
  uploadedBy String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  expense  Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@map("receipts")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  EXPENSE_ADDED
  EXPENSE_UPDATED
  EXPENSE_DELETED
  SETTLEMENT_REQUESTED
  SETTLEMENT_COMPLETED
  GROUP_INVITE
  BALANCE_REMINDER
}
